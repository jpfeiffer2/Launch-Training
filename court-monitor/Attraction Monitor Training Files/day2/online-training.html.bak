<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Day 2 Online Training</title>
<style>
:root{--g:#6cc24a;--gd:#4da62d;--y:#f2e600;--ink:#0f1720;--shadow:0 22px 60px rgba(0,0,0,.28)}
.start-overlay{position:fixed;inset:0;z-index:9999;background:radial-gradient(circle at 20% 20%,rgba(108,194,74,.38),transparent 28%),linear-gradient(135deg,rgba(0,0,0,.94),rgba(16,24,18,.96));display:grid;place-items:center;padding:28px;color:#fff}
.start-card{width:min(640px,92vw);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.20);border-radius:28px;box-shadow:0 24px 80px rgba(0,0,0,.45);padding:34px;text-align:center}
.start-card .eyebrow{color:var(--g);letter-spacing:2px;text-transform:uppercase;font-weight:900;font-size:.82rem;margin-bottom:8px}
.start-card h2{margin:0 0 12px;font-size:2.4rem;line-height:1.05;color:#fff}
.start-card p{margin:0 auto 22px;max-width:520px;color:#dbe7df;line-height:1.55;font-size:1.05rem}
.start-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.start-actions button{border:0;border-radius:999px;padding:13px 22px;font-weight:900;cursor:pointer;font-size:1rem}
.start-actions .btn-primary{background:linear-gradient(135deg,var(--g),var(--y));color:#061006}
.start-actions .btn-dark{background:#111;color:#fff;border:1px solid rgba(255,255,255,.25)}
*{box-sizing:border-box}html,body{height:100%;overflow:hidden}body{margin:0;font-family:Arial,Helvetica,sans-serif;background:radial-gradient(circle at 18% 15%,rgba(108,194,74,.30),transparent 27%),radial-gradient(circle at 85% 18%,rgba(242,230,0,.15),transparent 29%),linear-gradient(135deg,#050606,#13191c 54%,#243119);color:var(--ink)}
.deck{height:100vh;width:100vw;display:flex;flex-direction:column;padding:20px;gap:13px}.topbar{display:flex;align-items:center;justify-content:space-between;color:#fff;gap:16px;flex-shrink:0}.brand{display:flex;align-items:center;gap:14px;min-width:0}.logo-mark{width:54px;height:54px;border-radius:50%;background:#111;border:3px solid var(--g);display:grid;place-items:center;font-weight:900;color:var(--y);box-shadow:0 0 0 3px rgba(242,230,0,.16)}.brand-title strong{display:block;font-size:1rem;letter-spacing:1px;text-transform:uppercase}.brand-title span{display:block;font-size:.86rem;color:#cdd5dd}.slide-counter{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);padding:9px 13px;border-radius:999px;font-weight:bold}
.stage{flex:1;min-height:0;display:grid;place-items:center;overflow:hidden}.slide{display:none;width:min(1180px,calc(100vw - 44px),calc((100vh - 172px) * 1.7778));aspect-ratio:16/9;max-height:calc(100vh - 172px);background:#fff;border-radius:24px;overflow:hidden;box-shadow:var(--shadow);position:relative}.slide.active{display:block}.bar{position:absolute;inset:0 auto auto 0;height:10px;width:100%;background:linear-gradient(90deg,var(--g),var(--y),var(--g));z-index:4}.header{position:absolute;top:24px;left:30px;right:30px;display:flex;align-items:center;justify-content:space-between;z-index:4}.eyebrow{text-transform:uppercase;letter-spacing:2px;color:#b8ff91;font-weight:900;font-size:.8rem}.pill{background:#101418;color:var(--y);padding:9px 14px;border-radius:999px;font-weight:900;text-transform:uppercase;font-size:.76rem;white-space:nowrap;border:1px solid rgba(255,255,255,.15)}
.placeholder-slide{background:linear-gradient(135deg,#07100b 0%,#101a15 52%,#1d2616 100%);color:#fff}
.day2-slide1-approved{background:#050606 url("../assets/day2-slide1-prevention-response-bg.png") center center/cover no-repeat;color:#fff}
.day2-slide1-approved:before{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(0,0,0,.92) 0%,rgba(0,0,0,.76) 34%,rgba(0,0,0,.30) 58%,rgba(0,0,0,.12) 100%);z-index:1}
.d2s1-wrap{position:absolute;inset:0;z-index:2;color:#fff}
.d2s1-left{position:absolute;top:5.4%;left:4%;bottom:5.2%;width:48%;display:flex;flex-direction:column;align-items:flex-start}
.d2s1-eyebrow{font-size:.78rem;font-weight:1000;letter-spacing:2.2px;color:#b8ff91;text-transform:uppercase;margin-bottom:10px}
.d2s1-title{width:100%;font-size:clamp(2.75rem,4.55vw,4.75rem);font-weight:1000;line-height:.91;letter-spacing:-2.5px;text-transform:uppercase;text-shadow:0 8px 30px rgba(0,0,0,.72)}
.d2s1-title .accent{display:block;color:var(--y)}
.d2s1-intro{width:82%;margin-top:18px;font-size:1rem;line-height:1.36;font-weight:800;color:#f4f7f4;text-shadow:0 4px 18px rgba(0,0,0,.8)}
.d2s1-intro strong{color:var(--g)}
.d2s1-cards{position:absolute;top:11%;right:3.4%;width:34%;display:grid;gap:14px}
.d2s1-card{display:grid;grid-template-columns:58px 1fr;align-items:center;gap:13px;min-height:108px;padding:15px 18px;background:rgba(7,10,8,.88);border:2px solid rgba(108,194,74,.86);border-radius:18px;box-shadow:0 12px 32px rgba(0,0,0,.38);backdrop-filter:blur(5px);opacity:0;transform:translateX(60px)}
.d2s1-card.visible{animation:d2s1In .65s ease-out forwards}
.d2s1-card .num{width:52px;height:52px;border-radius:50%;display:grid;place-items:center;background:linear-gradient(145deg,var(--y),#b9ec00);color:#111;font-size:1.55rem;font-weight:1000;box-shadow:0 7px 16px rgba(0,0,0,.3)}
.d2s1-card h3{margin:0 0 4px;color:#fff;font-size:1.18rem;line-height:1;text-transform:uppercase}
.d2s1-card p{margin:0;color:#dce7de;font-size:.83rem;line-height:1.28;font-weight:700}
.d2s1-takeaway{width:100%;margin-top:auto;padding:14px 19px;border-radius:18px;background:rgba(0,0,0,.84);border-left:8px solid var(--y);color:#fff;font-size:.96rem;line-height:1.28;font-weight:1000;text-transform:uppercase;box-shadow:0 12px 30px rgba(0,0,0,.36);opacity:0;transform:translateY(28px)}
.d2s1-takeaway.visible{animation:d2s1Up .65s ease-out forwards}
.d2s1-takeaway span{color:var(--g)}
@keyframes d2s1In{to{opacity:1;transform:translateX(0)}}
@keyframes d2s1Up{to{opacity:1;transform:translateY(0)}}
@media(max-width:800px){.d2s1-left{top:4%;left:3%;bottom:4%;width:53%}.d2s1-title{font-size:2.25rem}.d2s1-intro{width:88%;margin-top:9px;font-size:.72rem}.d2s1-cards{right:2.5%;top:10%;width:41%;gap:7px}.d2s1-card{min-height:75px;padding:8px 10px;grid-template-columns:38px 1fr;gap:8px}.d2s1-card .num{width:34px;height:34px;font-size:1rem}.d2s1-card h3{font-size:.8rem}.d2s1-card p{font-size:.62rem}.d2s1-takeaway{font-size:.67rem;padding:9px 12px}}
.day2-slide2-values{background:radial-gradient(circle at 14% 18%,rgba(108,194,74,.22),transparent 29%),radial-gradient(circle at 58% 84%,rgba(242,230,0,.12),transparent 32%),linear-gradient(135deg,#030504 0%,#0a100c 56%,#151a10 100%);color:#fff}
.day2-slide2-values:before{content:"";position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.026) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.026) 1px,transparent 1px);background-size:42px 42px;opacity:.45}
.d2s2-wrap{position:absolute;inset:0;z-index:2;color:#fff;overflow:hidden}
.d2s2-left{position:absolute;left:4.2%;top:5.2%;bottom:5.2%;width:55.5%;display:flex;flex-direction:column;align-items:flex-start}
.d2s2-eyebrow{font-size:.78rem;font-weight:1000;letter-spacing:2.3px;color:#b8ff91;text-transform:uppercase;margin-bottom:10px}
.d2s2-title{font-size:clamp(3.15rem,5.35vw,5.45rem);font-weight:1000;line-height:.9;letter-spacing:-3px;text-transform:uppercase;text-shadow:0 10px 30px rgba(0,0,0,.5)}
.d2s2-title span{display:block;color:var(--y)}
.d2s2-intro{margin-top:16px;max-width:610px;color:#f2f6f2;font-size:1rem;line-height:1.35;font-weight:800}
.d2s2-intro strong{color:var(--g)}
.d2s2-values-label{margin-top:20px;color:#b8ff91;font-weight:1000;letter-spacing:1.7px;text-transform:uppercase;font-size:.77rem}
.d2s2-values{width:100%;margin-top:10px;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}
.d2s2-value{min-height:48px;padding:10px 9px;border-radius:13px;background:rgba(255,255,255,.085);border:1px solid rgba(255,255,255,.18);display:flex;align-items:center;gap:8px;color:#fff;font-size:.78rem;font-weight:1000;text-transform:uppercase;letter-spacing:.35px;box-shadow:0 8px 20px rgba(0,0,0,.2);opacity:0;transform:translateY(18px);transition:opacity .5s ease,transform .5s ease,border-color .5s ease}
.d2s2-value.visible{opacity:1;transform:translateY(0);border-color:rgba(108,194,74,.68)}
.d2s2-value:before{content:"";width:12px;height:12px;border-radius:50%;flex:0 0 12px;background:linear-gradient(145deg,var(--y),var(--g));box-shadow:0 0 0 3px rgba(108,194,74,.13)}
.d2s2-takeaway{margin-top:auto;width:100%;padding:13px 17px;border-radius:16px;background:rgba(0,0,0,.78);border-left:7px solid var(--g);color:#fff;font-size:.9rem;line-height:1.26;font-weight:1000;text-transform:uppercase;box-shadow:0 12px 28px rgba(0,0,0,.34);opacity:0;transform:translateY(22px);transition:opacity .55s ease,transform .55s ease}
.d2s2-takeaway.visible{opacity:1;transform:translateY(0)}
.d2s2-takeaway span{color:var(--y)}
.d2s2-poster-shell{position:absolute;right:2.5%;top:3.6%;bottom:3.6%;width:36%;border-radius:21px;background:linear-gradient(145deg,rgba(108,194,74,.18),rgba(242,230,0,.08));border:2px solid rgba(108,194,74,.74);box-shadow:0 20px 48px rgba(0,0,0,.48);display:grid;place-items:center;padding:10px;opacity:0;transform:translateX(35px);transition:opacity .7s ease,transform .7s ease}
.d2s2-poster-shell.visible{opacity:1;transform:translateX(0)}
.d2s2-poster{width:100%;height:100%;object-fit:contain;display:block;border-radius:14px;background:#070707}
@media(max-width:800px){.d2s2-left{left:3%;top:4%;bottom:4%;width:58%}.d2s2-title{font-size:2.35rem}.d2s2-intro{font-size:.68rem;margin-top:8px}.d2s2-values-label{margin-top:10px;font-size:.58rem}.d2s2-values{grid-template-columns:repeat(2,minmax(0,1fr));gap:5px;margin-top:6px}.d2s2-value{min-height:30px;padding:5px 6px;font-size:.56rem;gap:5px}.d2s2-value:before{width:8px;height:8px;flex-basis:8px}.d2s2-takeaway{font-size:.58rem;padding:7px 9px}.d2s2-poster-shell{right:1.7%;top:3%;bottom:3%;width:37%;padding:5px;border-radius:13px}}
.placeholder-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px);background-size:38px 38px;mask-image:linear-gradient(90deg,#000,transparent 85%)}.placeholder-slide:after{content:"";position:absolute;width:480px;height:480px;border-radius:50%;right:-110px;bottom:-180px;background:radial-gradient(circle,rgba(108,194,74,.28),transparent 68%)}.placeholder-content{position:absolute;z-index:2;inset:92px 48px 52px;display:grid;grid-template-columns:180px 1fr;gap:38px;align-items:center}.slide-number{font-size:8.5rem;font-weight:1000;line-height:1;color:rgba(242,230,0,.92);letter-spacing:-10px;text-shadow:0 12px 35px rgba(0,0,0,.35)}.placeholder-copy{max-width:790px}.status{display:inline-block;color:#0c130a;background:var(--g);border-radius:999px;padding:8px 13px;font-weight:1000;font-size:.72rem;letter-spacing:1px;margin-bottom:20px}h1{font-size:clamp(2.7rem,5.3vw,5.2rem);line-height:.94;letter-spacing:-2px;margin:0;color:#fff}.objective{font-size:1.35rem;line-height:1.34;color:#dce5de;margin:20px 0 28px;max-width:820px}.planning-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}.planning-card{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.16);border-radius:18px;padding:15px 17px;min-height:92px;backdrop-filter:blur(4px)}.planning-card span{display:block;color:#b8c3ba;font-size:.75rem;font-weight:900;text-transform:uppercase;letter-spacing:1px;margin-bottom:7px}.planning-card strong{display:block;color:#fff;font-size:1rem;line-height:1.28}
.controls{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-shrink:0}.home-link{color:#fff;text-decoration:none;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);padding:11px 15px;border-radius:999px;font-weight:800}.control-group{display:flex;gap:10px;align-items:center}button{border:0;border-radius:999px;padding:12px 18px;font-weight:900;cursor:pointer}.navbtn{background:#eef2f5;color:#111}.speak{background:#4b544a;color:#fff;cursor:pointer}.primary{background:var(--y);color:#000}button:disabled{opacity:.48;cursor:not-allowed}
@media(max-width:800px){.placeholder-content{grid-template-columns:1fr;gap:8px;inset:80px 28px 35px}.slide-number{font-size:4rem;letter-spacing:-4px}h1{font-size:2.4rem}.objective{font-size:1rem;margin:12px 0 16px}.planning-row{grid-template-columns:1fr}.planning-card{min-height:auto}}
</style></head>
<body>
<div class="start-overlay" id="startOverlay">
  <div class="start-card">
    <div class="eyebrow">Day 2 Online Training</div>
    <h2>Begin Day 2 Training</h2>
    <p>Press start to begin the slideshow. Narration will play automatically, and the Next button will unlock after the required narration is complete.</p>
    <div class="start-actions">
      <button class="btn-primary" onclick="startTraining()" type="button">Start Day 2 Training</button>
      <button class="btn-dark" onclick="toggleFullScreen()" type="button">Full Screen</button>
    </div>
  </div>
</div>
<main class="deck">
  <div class="topbar"><div class="brand"><div class="logo-mark">L</div><div class="brand-title"><strong>Launch Attraction Monitor Training</strong><span>Day 2 · Standards, Readiness, and Injury Response</span></div></div><div class="slide-counter"><span id="cur">1</span> / <span id="total">15</span></div></div>
  <div class="stage"><section class="slide day2-slide1-approved active" data-slide="1" aria-label="Day 2 Slide 1: When Prevention Is Not Enough">
      <div class="d2s1-wrap">
        <div class="d2s1-left">
          <div class="d2s1-eyebrow">DAY 2 · SLIDE 1</div>
          <div class="d2s1-title">When Prevention <span class="accent">Is Not Enough</span></div>
          <div class="d2s1-intro">Day 1 focused on <strong>preventing unsafe situations.</strong> Day 2 focuses on what happens when an incident still occurs—and how your response protects everyone around it.</div>
          <div class="d2s1-takeaway">You may not be able to prevent every injury—but <span>your response can prevent the situation from becoming worse.</span></div>
        </div>
        <div class="d2s1-cards">
          <div class="d2s1-card"><div class="num">1</div><div><h3>Stay Calm</h3><p>Panic creates confusion. A controlled response begins with the monitor remaining composed.</p></div></div>
          <div class="d2s1-card"><div class="num">2</div><div><h3>Protect the Area</h3><p>Stop nearby activity and prevent the incident from becoming a second injury.</p></div></div>
          <div class="d2s1-card"><div class="num">3</div><div><h3>Get the Right Help</h3><p>Notify a Supervisor or Manager and follow the correct response procedure.</p></div></div>
        </div>
      </div>
    </section><section class="slide day2-slide2-values" data-slide="2" aria-label="Day 2 Slide 2: Our Vision and Core Values">
      <div class="d2s2-wrap">
        <div class="d2s2-left">
          <div class="d2s2-eyebrow">DAY 2 · SLIDE 2</div>
          <div class="d2s2-title">Our Vision <span>To Create Awesome Memories</span></div>
          <div class="d2s2-intro">Every decision we make—from enforcing a rule to helping an injured guest—should support this vision. Our <strong>Core Values</strong> guide how we protect guests, support one another, and represent Launch.</div>
          <div class="d2s2-values-label">Our Core Values</div>
          <div class="d2s2-values">
            <div class="d2s2-value">Commitment</div>
            <div class="d2s2-value">Safety</div>
            <div class="d2s2-value">Transparency</div>
            <div class="d2s2-value">Fulfillment</div>
            <div class="d2s2-value">Teamwork</div>
            <div class="d2s2-value">Development</div>
            <div class="d2s2-value">Growth</div>
          </div>
          <div class="d2s2-takeaway">Our values guide how we <span>protect guests, support one another, and create memorable experiences.</span></div>
        </div>
        <div class="d2s2-poster-shell"><img class="d2s2-poster" src="../assets/day2-slide2-core-values.jpg" alt="Launch Family Entertainment Core Values and Vision poster"></div>
      </div>
    </section><section class="slide placeholder-slide" data-slide="3">
      <div class="placeholder-grid"></div>
      <div class="bar"></div>
      <div class="header">
        <div class="eyebrow">DAY 2 · SLIDE 3</div>
        <div class="pill">Culture</div>
      </div>
      <div class="placeholder-content">
        <div class="slide-number">03</div>
        <div class="placeholder-copy">
          <div class="status">STRUCTURE LOCKED · VISUAL DESIGN PENDING</div>
          <h1>Core Values in Action</h1>
          <p class="objective">Apply Commitment, Safety, Transparency, Fulfillment, Teamwork, Development, and Growth to real shift decisions.</p>
          <div class="planning-row">
            <div class="planning-card"><span>Learning focus</span><strong>Culture</strong></div>
            <div class="planning-card"><span>Policy source</span><strong>2026 Core Values graphic</strong></div>
          </div>
        </div>
      </div>
    </section><section class="slide placeholder-slide" data-slide="4">
      <div class="placeholder-grid"></div>
      <div class="bar"></div>
      <div class="header">
        <div class="eyebrow">DAY 2 · SLIDE 4</div>
        <div class="pill">Professional Readiness</div>
      </div>
      <div class="placeholder-content">
        <div class="slide-number">04</div>
        <div class="placeholder-copy">
          <div class="status">STRUCTURE LOCKED · VISUAL DESIGN PENDING</div>
          <h1>Uniform Standards</h1>
          <p class="objective">Understand the approved uniform, identification, footwear, and appearance requirements for Attraction Monitors.</p>
          <div class="planning-row">
            <div class="planning-card"><span>Learning focus</span><strong>Professional Readiness</strong></div>
            <div class="planning-card"><span>Policy source</span><strong>2026 Uniform Policy</strong></div>
          </div>
        </div>
      </div>
    </section><section class="slide placeholder-slide" data-slide="5">
      <div class="placeholder-grid"></div>
      <div class="bar"></div>
      <div class="header">
        <div class="eyebrow">DAY 2 · SLIDE 5</div>
        <div class="pill">Professional Readiness</div>
      </div>
      <div class="placeholder-content">
        <div class="slide-number">05</div>
        <div class="placeholder-copy">
          <div class="status">STRUCTURE LOCKED · VISUAL DESIGN PENDING</div>
          <h1>Ready for Your Shift</h1>
          <p class="objective">Report to position with the required equipment, proper footwear, and awareness of current attraction conditions.</p>
          <div class="planning-row">
            <div class="planning-card"><span>Learning focus</span><strong>Professional Readiness</strong></div>
            <div class="planning-card"><span>Policy source</span><strong>2026 Uniform Policy + 2026 Injury SOP</strong></div>
          </div>
        </div>
      </div>
    </section><section class="slide placeholder-slide" data-slide="6">
      <div class="placeholder-grid"></div>
      <div class="bar"></div>
      <div class="header">
        <div class="eyebrow">DAY 2 · SLIDE 6</div>
        <div class="pill">Standards</div>
      </div>
      <div class="placeholder-content">
        <div class="slide-number">06</div>
        <div class="placeholder-copy">
          <div class="status">STRUCTURE LOCKED · VISUAL DESIGN PENDING</div>
          <h1>Cleaning and Attraction Presentation</h1>
          <p class="objective">Maintain a clean, organized, guest-ready attraction while following approved park procedures.</p>
          <div class="planning-row">
            <div class="planning-card"><span>Learning focus</span><strong>Standards</strong></div>
            <div class="planning-card"><span>Policy source</span><strong>Operational standards + local procedures</strong></div>
          </div>
        </div>
      </div>
    </section><section class="slide placeholder-slide" data-slide="7">
      <div class="placeholder-grid"></div>
      <div class="bar"></div>
      <div class="header">
        <div class="eyebrow">DAY 2 · SLIDE 7</div>
        <div class="pill">Standards</div>
      </div>
      <div class="placeholder-content">
        <div class="slide-number">07</div>
        <div class="placeholder-copy">
          <div class="status">STRUCTURE LOCKED · VISUAL DESIGN PENDING</div>
          <h1>Clean Without Abandoning Your Zone</h1>
          <p class="objective">Address trash and cleanliness without losing coverage or becoming distracted from active monitoring.</p>
          <div class="planning-row">
            <div class="planning-card"><span>Learning focus</span><strong>Standards</strong></div>
            <div class="planning-card"><span>Policy source</span><strong>Day 1 coverage standard</strong></div>
          </div>
        </div>
      </div>
    </section><section class="slide placeholder-slide" data-slide="8">
      <div class="placeholder-grid"></div>
      <div class="bar"></div>
      <div class="header">
        <div class="eyebrow">DAY 2 · SLIDE 8</div>
        <div class="pill">Safety Response</div>
      </div>
      <div class="placeholder-content">
        <div class="slide-number">08</div>
        <div class="placeholder-copy">
          <div class="status">STRUCTURE LOCKED · VISUAL DESIGN PENDING</div>
          <h1>Damaged Equipment and Attraction Closure</h1>
          <p class="objective">Stop participation, clear access, and notify leadership whenever unsafe equipment or conditions are identified.</p>
          <div class="planning-row">
            <div class="planning-card"><span>Learning focus</span><strong>Safety Response</strong></div>
            <div class="planning-card"><span>Policy source</span><strong>2026 Main Court / Injury SOP</strong></div>
          </div>
        </div>
      </div>
    </section><section class="slide placeholder-slide" data-slide="9">
      <div class="placeholder-grid"></div>
      <div class="bar"></div>
      <div class="header">
        <div class="eyebrow">DAY 2 · SLIDE 9</div>
        <div class="pill">Injury Response</div>
      </div>
      <div class="placeholder-content">
        <div class="slide-number">09</div>
        <div class="placeholder-copy">
