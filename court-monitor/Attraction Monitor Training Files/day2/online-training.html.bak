  <div class="controls"><a class="home-link" href="./index.html">← Day 2 Menu</a><div class="control-group"><button class="navbtn" id="prev">Back</button><button class="speak" id="speak">Play Narration</button><button aria-disabled="true" class="primary" disabled id="next">Next</button></div></div>
</main>
<script>
const slides=[...document.querySelectorAll('.slide')];
let idx=0;
let trainingStarted=false;
let narrationStarted=false;
const completedNarration=new Set();
const maxPlayedTime=new Map();

const cur=document.getElementById('cur');
const total=document.getElementById('total');
const prev=document.getElementById('prev');
const next=document.getElementById('next');
const speak=document.getElementById('speak');
total.textContent=slides.length;

const recordedNarration={
  0:'../audio/day2_slide1.m4a'
};
const audioPlayer=new Audio();
audioPlayer.preload='auto';

function hasRecordedAudio(index=idx){
  return Object.prototype.hasOwnProperty.call(recordedNarration,index);
}
function currentNarrationComplete(){
  return !hasRecordedAudio(idx) || completedNarration.has(idx);
}
function setNextLocked(locked){
  next.disabled=locked;
  next.setAttribute('aria-disabled', locked ? 'true' : 'false');
  next.title=locked ? 'Complete the slide narration to continue.' : '';
}
function updateNarrationControls(){
  const hasAudio=hasRecordedAudio();
  speak.disabled=!trainingStarted || !hasAudio;
  if(!hasAudio) speak.textContent='Narration Pending';
  else if(completedNarration.has(idx)) speak.textContent='Replay Narration';
  else if(narrationStarted) speak.textContent='Narration Playing';
  else speak.textContent='Play Narration';
  setNextLocked(hasAudio && !completedNarration.has(idx));
}
function stopAudio(reset=true){
  audioPlayer.pause();
  if(reset){try{audioPlayer.currentTime=0;}catch(e){}}
  narrationStarted=false;
}
function loadCurrentAudio(){
  const src=recordedNarration[idx];
  if(!src) return false;
  const resolved=new URL(src,window.location.href).href;
  if(audioPlayer.src!==resolved){
    audioPlayer.src=src;
    audioPlayer.load();
  }
  return true;
}
async function playNarration(){
  if(!trainingStarted || !loadCurrentAudio()) return;
  if(completedNarration.has(idx)){try{audioPlayer.currentTime=0;}catch(e){}}
  try{
    await audioPlayer.play();
    narrationStarted=true;
  }catch(e){
    narrationStarted=false;
  }
  updateNarrationControls();
}
function startTraining(){
  trainingStarted=true;
  const overlay=document.getElementById('startOverlay');
  if(overlay) overlay.style.display='none';
  show(0,true);
}
function toggleFullScreen(){
  if(!document.fullscreenElement) document.documentElement.requestFullscreen?.();
  else document.exitFullscreen?.();
}
function resetSlide1TimedElements(){
  const slide=slides[0];
  if(!slide) return;
  slide.querySelectorAll('.d2s1-card,.d2s1-takeaway').forEach(el=>{
    el.classList.remove('visible');
    el.style.animation='none';
    void el.offsetWidth;
    el.style.animation='';
  });
}
function syncSlide1TimedElements(){
  if(idx!==0) return;
  const slide=slides[0];
  if(!slide) return;
  const t=audioPlayer.currentTime||0;
  const markers=[
    ['.d2s1-card:nth-child(1)',21],
    ['.d2s1-card:nth-child(2)',35],
    ['.d2s1-card:nth-child(3)',41],
    ['.d2s1-takeaway',57]
  ];
  markers.forEach(([selector,seconds])=>{
    const el=slide.querySelector(selector);
    if(el && t>=seconds) el.classList.add('visible');
  });
}


let slide2Timers=[];
function clearSlide2Timers(){slide2Timers.forEach(clearTimeout);slide2Timers=[];}
function resetSlide2Preview(){
  clearSlide2Timers();
  const slide=slides[1];
  if(!slide) return;
  slide.querySelectorAll('.d2s2-value,.d2s2-takeaway,.d2s2-poster-shell').forEach(el=>el.classList.remove('visible'));
}
function runSlide2Preview(){
  const slide=slides[1];
  if(!slide) return;
  const poster=slide.querySelector('.d2s2-poster-shell');
  if(poster) slide2Timers.push(setTimeout(()=>poster.classList.add('visible'),180));
  const values=[...slide.querySelectorAll('.d2s2-value')];
  values.forEach((el,n)=>slide2Timers.push(setTimeout(()=>el.classList.add('visible'),700+n*220)));
  const takeaway=slide.querySelector('.d2s2-takeaway');
  if(takeaway) slide2Timers.push(setTimeout(()=>takeaway.classList.add('visible'),2500));
}

audioPlayer.addEventListener('timeupdate',()=>{
  const maxSoFar=maxPlayedTime.get(idx)||0;
  if(audioPlayer.currentTime>maxSoFar) maxPlayedTime.set(idx,audioPlayer.currentTime);
  syncSlide1TimedElements();
});
audioPlayer.addEventListener('seeking',()=>{
  const maxSoFar=maxPlayedTime.get(idx)||0;
  if(!completedNarration.has(idx) && audioPlayer.currentTime>maxSoFar+1){
    audioPlayer.currentTime=maxSoFar;
  }
});
audioPlayer.addEventListener('ended',()=>{
  completedNarration.add(idx);
  maxPlayedTime.set(idx,audioPlayer.duration||audioPlayer.currentTime);
  narrationStarted=false;
  updateNarrationControls();
});
audioPlayer.addEventListener('play',()=>{
  narrationStarted=true;
  syncSlide1TimedElements();
  updateNarrationControls();
});
audioPlayer.addEventListener('pause',()=>{
  if(!audioPlayer.ended) narrationStarted=false;
  updateNarrationControls();
});

function show(i,shouldAutoPlay=true){
  stopAudio();
  clearSlide2Timers();
  idx=i;
  slides.forEach((s,n)=>s.classList.toggle('active',n===idx));
  if(idx===0){
    resetSlide1TimedElements();
    if(completedNarration.has(idx)){
      slides[0]?.querySelectorAll('.d2s1-card,.d2s1-takeaway').forEach(el=>el.classList.add('visible'));
    }
  }
  if(idx===1){
    resetSlide2Preview();
    if(trainingStarted) runSlide2Preview();
  }
  cur.textContent=idx+1;
  prev.disabled=idx===0;
  next.textContent=idx===slides.length-1?'Finish':'Next';
  updateNarrationControls();
  if(trainingStarted && shouldAutoPlay && hasRecordedAudio() && !completedNarration.has(idx)) playNarration();
}
function nextSlide(){
  if(!currentNarrationComplete()){
    updateNarrationControls();
    return;
  }
  if(idx<slides.length-1) show(idx+1,true);
  else location.href='./index.html';
}
function prevSlide(){if(idx>0) show(idx-1,false);}
prev.onclick=prevSlide;
next.onclick=nextSlide;
speak.onclick=playNarration;

document.addEventListener('keydown',(e)=>{
  if(e.ctrlKey && e.shiftKey && String(e.key||'').toLowerCase()==='f'){
    e.preventDefault();
    stopAudio();
    completedNarration.add(idx);
    if(idx<slides.length-1) show(idx+1,true);
    else location.href='./index.html';
    return;
  }
  if(e.key==='ArrowRight' || e.key===' '){e.preventDefault();nextSlide();}
  if(e.key==='ArrowLeft'){e.preventDefault();prevSlide();}
  if(!e.ctrlKey && !e.shiftKey && String(e.key||'').toLowerCase()==='f') toggleFullScreen();
});
show(0,false);
</script></body></html>